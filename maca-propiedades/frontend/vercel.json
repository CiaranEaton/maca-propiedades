{
  "buildCommand": "yarn build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
